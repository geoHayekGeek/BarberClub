NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://username:password@localhost:5432/barber_club?schema=public
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/barber_club_test?schema=public
WEBSITE_DATABASE_URL=postgresql://username:password@localhost:5432/barberclub_site?schema=public

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info

FRONTEND_URL=http://localhost:5173

BACKEND_PUBLIC_URL=http://localhost:3000

# Brevo transactional email (preferred for forgot-password)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
# Optional fallbacks if you already reuse the website backend env names
BREVO_API_KEY_GRENOBLE=
BREVO_SENDER_EMAIL_GRENOBLE=
BREVO_SENDER_NAME_GRENOBLE=

# SMTP fallback if Brevo is not configured
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

LOYALTY_TARGET=10
LOYALTY_QR_TTL_SECONDS=120
QR_TOKEN_PEPPER=change_this_to_long_random_string_min_32_chars

ENABLE_LOCAL_CANCEL=false

ADMIN_SECRET=change-me-in-production

# Path to Firebase service account JSON (for FCM push notifications)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/service-account.json
